# EduPath API — FastAPI + SQLite, self-contained (seed DB baked in).
# Build from the REPO ROOT:  docker build -f deploy/Dockerfile.api .
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /srv

COPY requirements-api.txt .
RUN pip install --no-cache-dir -r requirements-api.txt

# API + the engine modules it imports (pure stdlib) + the seed snapshot.
COPY api/ api/
COPY app/ app/
COPY scripts/ scripts/
COPY deploy/edupath.db.gz deploy/edupath.db.gz
COPY deploy/start.sh deploy/start.sh

# Persistent-disk location; start.sh seeds it on first boot.
ENV EDUPATH_DB_PATH=/data/edupath.db
EXPOSE 8000

CMD ["/bin/sh", "deploy/start.sh"]
