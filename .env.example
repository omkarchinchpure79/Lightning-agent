# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# REQUIRED — secret used to sign counsellor JWTs (api/auth_utils.py refuses to
# sign without it). Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-hex-string

# Optional: JWT lifetime in days (default 30)
# JWT_EXPIRE_DAYS=30

# Required for AI college description generation (claude-haiku-4-5).
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# Optional: override the DB path (defaults to db/edupath.db relative to repo root)
# EDUPATH_DB_PATH=/absolute/path/to/edupath.db
