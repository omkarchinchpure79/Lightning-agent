# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required — signs/verifies counsellor JWTs. The API refuses to start signing
# tokens with an empty secret. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-random-64-char-hex-string

# Optional — JWT lifetime in days (default 30 if unset).
# JWT_EXPIRE_DAYS=30

# Optional — comma-separated list of frontend origins allowed to call this API.
# Defaults to http://localhost:3000 for local dev. Set to the deployed
# frontend's real origin(s) in production, e.g.:
# ALLOWED_ORIGINS=https://edupath.vercel.app

# Required for AI college description generation (claude-haiku-4-5).
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# Optional: override the DB path (defaults to db/edupath.db relative to repo root)
# EDUPATH_DB_PATH=/absolute/path/to/edupath.db
