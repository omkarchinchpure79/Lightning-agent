# Database
db/*.db

# Raw PDFs (large, re-downloadable)
data/raw/pdfs/*.pdf
data/raw/pdfs/**/*.pdf

# Intermediate parsed data (large, regenerable via scripts/parse_cutoffs.py /
# scripts/parse_dse_cutoffs.py)
data/processed/cutoffs.json
data/processed/dse_cutoffs.json
data/processed/dse_flagged.json

# College campus photos: committed (333MB, ~2600 small JPGs, none over 1MB) so
# they can be served for free via raw.githubusercontent.com in production —
# see IMAGE_CDN_BASE in scripts/college_card_api.py. Re-downloadable via
# scripts/download_college_images.py if this history is ever squashed.

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# IDE
.vscode/
*.code-workspace

# OS
Thumbs.db
.DS_Store

# Env files — NEVER commit keys
.env
.env.local
.env.*.local

# Personal Claude overrides
CLAUDE.local.md
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Session/scrape artifacts
SESSION_TRANSCRIPT.md
bing_raw.html

# Playwright artifacts
web/test-results/
web/playwright-report/

# Obsidian vault workspace config (local editor state)
.obsidian/

# Local run logs
logs/

# Local design reference dumps (extracted handoff, 53MB — not app code)
hearth_design/

# Vercel CLI project link (contains project/org IDs)
.vercel/
web/.vercel/

.vercel
.env*
